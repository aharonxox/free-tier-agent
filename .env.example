# ============================================================
# FREE-TIER AGENT - Environment Variables
# ============================================================
# Copy this file to .env and fill in your real API keys.
# NEVER commit your real .env file to GitHub.
# ============================================================

# --- Google Gemini (free tier) ---
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# --- Groq (free tier - very fast Llama-3) ---
# Get key: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# --- Mistral (free tier) ---
# Get key: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your-mistral-api-key-here

# --- Agent Behavior ---
# Max loop iterations before forcing a stop (default: 5)
MAX_STEPS=5

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
